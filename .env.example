# OptiMat Alloys Environment Variables
# Copy this file to .env and fill in your values

# Ollama API Key (Required for cloud models — the default)
# Sign up at https://ollama.com/ and get your API key from account settings.
# Cloud models (e.g., gpt-oss:120b-cloud) run remotely — no GPU needed.
#
OLLAMA_API_KEY=your-ollama-api-key

# OpenRouter API Key (Optional — for free cloud models as alternative)
# Get your API key from: https://openrouter.ai/keys
# Only needed if you want to use OpenRouter models.
#
# Rate Limits:
# - Without $10+ credits: 50 requests/day, 20 requests/minute
# - With $10+ credits:    1,000 requests/day, 20 requests/minute
# Note: Credits are NOT consumed by free models — they just unlock higher limits.
#
OPENROUTER_API_KEY=your-openrouter-api-key

# PyTorch Compilation (RECOMMENDED: Keep disabled for CUDA 12.4)
# Known issue: torch.compile with CUDA 12.4 can cause KeyError in inductor backend
# Disabling provides stable operation with minimal performance impact
TORCH_COMPILE_DISABLE=1

# Optional: Specify which GPU(s) to use (for multi-GPU systems)
# Uncomment and set to GPU index (e.g., 0, 1, or 0,1 for multiple)
# CUDA_VISIBLE_DEVICES=0

# Optional: Set PyTorch number of threads
# Uncomment to limit CPU thread usage
# OMP_NUM_THREADS=8

# Optional: Control logging verbosity for AutoGen and other libraries
# Values: DEBUG, INFO, WARNING (default), ERROR, CRITICAL
# Set to DEBUG to see detailed message publishing and serialization logs
# Set to WARNING (or leave commented) for clean console output
# LOG_LEVEL=WARNING

# Optional: PostgreSQL Database Connection (Future Feature)
# Currently, OptiMat Alloys uses local SQLite database (structures/database.db)
# PostgreSQL support is available for optional data sharing/archiving via migration script
#
# To use shared PostgreSQL database (future feature, not yet implemented in app):
# 1. Deploy PostgreSQL on Railway.app (see docs/deployment/INITIAL_SETUP.md)
# 2. Get DATABASE_URL from Railway dashboard
# 3. Uncomment and set DATABASE_URL below
#
# Format: postgresql://user:password@host:port/database?sslmode=require
# Example from Railway: postgresql://postgres:abc123@region.railway.app:5432/railway
#
# DATABASE_URL=postgresql://postgres:password@host:port/database

# NequIP Worker Configuration (Optional - only needed if using NequIP calculators)
# These settings allow running OptiMat Alloys on systems with non-standard conda installations
#
# Path to the optimat-nequip conda environment bin directory
# Default: ~/miniconda3/envs/optimat-nequip/bin
# Examples:
#   /opt/conda/envs/optimat-nequip/bin (Docker/system conda)
#   ~/anaconda3/envs/optimat-nequip/bin (Anaconda installation)
#   /home/user/miniforge3/envs/optimat-nequip/bin (Miniforge)
# NEQUIP_ENV_PATH=/path/to/conda/envs/optimat-nequip/bin

# Path to store compiled NequIP models (device-specific cache)
# Default: ~/.cache/nequip
# NEQUIP_CACHE_DIR=/path/to/nequip/cache

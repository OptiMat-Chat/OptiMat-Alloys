*.tar.bz2

# === Materials Science / OptiMat Alloys Specific ===

# Structure database (large, contains all simulation results)
structures/
structures/database.db
structures/database.json

# Structure trajectories (can be large)
*.traj
*.xyz

# Data directory (reference data, radii, element support)
# Uncomment below to ignore data files (they can be regenerated)
# data/reference/
# data/element_support/
# Note: data/radii/ should be tracked (atomic_radii.json is source data)

# Session data (old architecture, now using global database)
sessions/

# OVITO rendered images (regenerated from database)
# Note: Keeping sample images in docs/ if added later
*.png
*.jpg
*.jpeg
!docs/**/*.png
!docs/**/*.jpg

# Large data files
*.hdf5
*.h5

# === Chainlit ===
.chainlit/
.files/
public/
chainlit.md


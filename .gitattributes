# Git attributes for OptiMat Alloys
# Ensures consistent line endings across Windows/WSL2/Linux

# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Shell scripts must have LF line endings
*.sh text eol=lf

# Python files
*.py text eol=lf

# YAML, TOML, JSON
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf

# Binary files (explicit)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.traj binary
